# DMC-VAZIX — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Supabase (public — safe to expose to browser) ──────────────────────────
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase (private — server-side ONLY, never expose to browser) ──────────
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DIRECT_CONNECTION_URL=
SUPABASE_DB_PASSWORD=

# ── Session signing secret (generate a long random string) ──────────────────
# Example: openssl rand -hex 32
SESSION_SECRET=
